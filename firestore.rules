rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is admin
    function isAdmin() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBlocked == false;
    }

    // Helper to check if user is accessing their own data
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      // Secure creation: Requires valid OTP in 'otps' collection
      allow create: if isOwner(userId) &&
                    exists(/databases/$(database)/documents/otps/$(request.resource.data.email)) &&
                    get(/databases/$(database)/documents/otps/$(request.resource.data.email)).data.code == request.resource.data.otp &&
                    get(/databases/$(database)/documents/otps/$(request.resource.data.email)).data.expiresAt > request.time.toMillis();

      allow update: if (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isPremium', 'isBlocked', 'premiumInfo', 'blockInfo'])) || isAdmin();
      allow delete: if isAdmin();

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /config/settings {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    match /admin_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /otps/{email} {
      // allow write: includes create and update. Required for resend.
      allow write: if request.auth != null || true; // Allowed for registration
      allow read, delete: if isAdmin() || (request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == email);
    }

    match /mail/{mailId} {
      allow create: if true; // Trigger email
    }

    // Attendance and other flat collections (if they exist)
    match /attendance/{docId} {
      allow read, write: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
